rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Hàm kiểm tra đăng nhập
    function isAuthenticated() {
      return request.auth != null;
    }

    // Hàm kiểm tra chủ sở hữu dữ liệu
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Hàm kiểm tra quyền Quản trị (Dựa trên Email hoặc Vai trò giáo viên)
    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == "singuyen.cnt@gmail.com" || 
              request.auth.token.email == "minhkhoiklk@gmail.com" ||
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher');
    }

    // Kiểm tra tính hợp lệ của dữ liệu người dùng
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'fullName', 'role']) &&
             data.uid is string &&
             data.role in ['student', 'teacher'];
    }

    // Kiểm tra tính hợp lệ của lộ trình (Assessment)
    function isValidAssessment(data) {
      return data.keys().hasAll(['userId', 'stage']) &&
             data.userId is string &&
             data.stage is number;
    }

    // Quy tắc cho bộ sưu tập USERS
    match /users/{userId} {
      allow read: if isAuthenticated();
      // Cho phép Admin tạo profile cho học sinh hoặc người dùng tự tạo profile cho mình
      allow create: if isAuthenticated() && (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    // Quy tắc cho bộ sưu tập ASSESSMENTS (Lộ trình & Nhật ký)
    match /assessments/{assessmentId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && (request.auth.uid == request.resource.data.userId || isAdmin()) && isValidAssessment(request.resource.data);
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow delete: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.userId);
    }
  }
}
