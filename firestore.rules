rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (UID)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - fullName: string (required)
    //   - className: string (optional)
    //   - role: string (required, 'student' or 'teacher')
    //   - createdAt: timestamp (required)
    //
    // Collection: assessments
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required)
    //   - stage: number (required, 1-4)
    //   - scores: map (HK scores)
    //   - targetScore: number
    //   - dailyTime: number
    //   - examType: string
    //   - topicConfidence: map
    //   - casioSkill: string
    //   - barriers: list
    //   - roadmapFocus: string
    //   - roadmap: string
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher' ||
         request.auth.token.email == "singuyen.cnt@gmail.com" ||
         request.auth.token.email == "minhkhoiklk@gmail.com");
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'fullName', 'role', 'createdAt']) &&
             data.uid is string &&
             data.email is string &&
             data.fullName is string &&
             data.role in ['student', 'teacher'];
    }

    function isValidAssessment(data) {
      return data.keys().hasAll(['userId', 'stage', 'createdAt']) &&
             data.userId is string &&
             data.stage is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    match /assessments/{assessmentId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && (request.auth.uid == request.resource.data.userId || isAdmin());
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
    }
  }
}
